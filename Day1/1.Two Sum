#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int key;
    int value;
} Pair;

int* twoSum(int* nums, int numsSize, int target, int* returnSize) {
    Pair map[numsSize];

    int mapSize = 0;
    static int res[2];

    for (int i = 0; i < numsSize; i++) {
        int complement = target - nums[i];

        // search complement 
        for (int j = 0; j < mapSize; j++) {
            if (map[j].key == complement) {
                res[0] = map[j].value;
                res[1] = i;
                *returnSize = 2;
                return res;
            }
        }

        // insert current number
        map[mapSize].key = nums[i];
        map[mapSize].value = i;
        mapSize++;
    }

    *returnSize = 0;
    return res;
}
